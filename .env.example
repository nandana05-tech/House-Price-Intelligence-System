# ─── Docker Compose ───────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=hpi

# ─── MCP Server ───────────────────────────────────────────────────────────
MCP_TRANSPORT=streamable-http
MCP_PORT=8000

# ─── OpenAI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=...
OPENAI_MODEL=gpt-4o

# ─── Kafka ────────────────────────────────────────────────────────────────
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID_REGRESSION=hpi-regression-pod
KAFKA_GROUP_ID_CLASSIFICATION=hpi-classification-pod
KAFKA_GROUP_ID_CLUSTERING=hpi-clustering-pod
KAFKA_GROUP_ID_FEEDBACK=hpi-feedback-pod

# ─── PostgreSQL / Prisma ──────────────────────────────────────────────────
DATABASE_URL=postgresql://hpi:hpi_secret@127.0.0.1:5435/house_price_intel?schema=prisma

# ─── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
PREDICTION_CACHE_TTL=3600

# ─── MLflow ───────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_REGRESSION=house-price-regression
MLFLOW_EXPERIMENT_CLASSIFICATION=house-price-classification
MLFLOW_EXPERIMENT_CLUSTERING=house-price-clustering

# ─── Retraining ───────────────────────────────────────────────────────────
RETRAIN_FEEDBACK_THRESHOLD=100

# ─── RAG ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
RAG_ENABLED=true
RAG_TOP_K_PROPERTIES=3
RAG_TOP_K_KNOWLEDGE=2